{
	admin off
	auto_https off          # Railway terminates TLS at the edge; we serve plain HTTP
	persist_config off
}

# Bind to Railway's $PORT (default 8080 for local docker runs).
:{$PORT:8080} {
	root * /srv
	encode gzip zstd
	file_server                       # serves index.html for directory requests
	header Cache-Control "public, max-age=3600"
	log {
		output stdout
		format console
	}
}
