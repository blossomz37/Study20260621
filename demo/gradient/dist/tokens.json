{
  "$description": "A luminous hero-banner design system built on layered CSS gradients \u2014 a violet\u2192 pink\u2192amber linear wash with a soft radial glow on top. Pilot case for the proposed `gradients` token group (stops in DTCG `$value`, orientation in `$extensions`).",
  "colors": {
    "primary": {
      "$type": "color",
      "$value": "#5b21b6"
    },
    "primary-strong": {
      "$type": "color",
      "$value": "#4c1d95"
    },
    "on-primary": {
      "$type": "color",
      "$value": "#f5f3ff"
    },
    "secondary": {
      "$type": "color",
      "$value": "#2563eb"
    },
    "tertiary": {
      "$type": "color",
      "$value": "#db2777"
    },
    "accent": {
      "$type": "color",
      "$value": "#f59e0b"
    },
    "surface": {
      "$type": "color",
      "$value": "#0b1020"
    },
    "surface-container": {
      "$type": "color",
      "$value": "#141a2e"
    },
    "on-surface": {
      "$type": "color",
      "$value": "#e8eaf2"
    },
    "on-surface-variant": {
      "$type": "color",
      "$value": "#a9b1c7"
    },
    "outline": {
      "$type": "color",
      "$value": "#2a3350"
    }
  },
  "typography": {
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Sora",
        "fontSize": "56px",
        "fontWeight": 700,
        "lineHeight": 1.05,
        "letterSpacing": "-0.02em"
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "18px",
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    },
    "label-caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "12px",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "0.12em"
      }
    }
  },
  "rounded": {
    "md": {
      "$type": "dimension",
      "$value": "12px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "20px"
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px"
    }
  },
  "spacing": {
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "32px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "64px",
      "$type": "dimension"
    }
  },
  "gradients": {
    "hero": {
      "$type": "gradient",
      "$value": [
        {
          "color": "{colors.primary}",
          "position": "0%"
        },
        {
          "color": "{colors.tertiary}",
          "position": "55%"
        },
        {
          "color": "{colors.accent}",
          "position": "100%"
        }
      ],
      "$extensions": {
        "designmd": {
          "type": "linear",
          "angle": "135deg"
        }
      }
    },
    "glow": {
      "$type": "gradient",
      "$value": [
        {
          "color": "rgba(37,99,235,0.55)",
          "position": "0%"
        },
        {
          "color": "rgba(37,99,235,0)",
          "position": "70%"
        }
      ],
      "$extensions": {
        "designmd": {
          "type": "radial",
          "angle": "circle at 28% 18%"
        }
      }
    }
  },
  "components": {
    "hero-banner": {
      "backgroundImage": {
        "$value": "{gradients.hero}"
      },
      "textColor": {
        "$value": "{colors.on-primary}"
      },
      "rounded": {
        "$value": "{rounded.lg}"
      },
      "padding": {
        "$value": "{spacing.xl}"
      }
    },
    "hero-glow": {
      "backgroundImage": {
        "$value": "{gradients.glow}"
      }
    },
    "swatch-hero": {
      "backgroundImage": {
        "$value": "{gradients.hero}"
      },
      "rounded": {
        "$value": "{rounded.md}"
      }
    },
    "badge": {
      "backgroundColor": {
        "$value": "{colors.surface-container}"
      },
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "typography": {
        "$value": "{typography.label-caps}"
      },
      "rounded": {
        "$value": "{rounded.full}"
      },
      "padding": {
        "$value": "{spacing.sm}"
      }
    }
  }
}
