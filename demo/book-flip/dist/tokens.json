{
  "$description": "A warm, literary design system for displaying book covers in a gallery that flips each cover to reveal the back cover or structured book info. Pilot case for the proposed `motion` token extension.",
  "colors": {
    "primary": {
      "$type": "color",
      "$value": "#3a2d28"
    },
    "primary-strong": {
      "$type": "color",
      "$value": "#241b17"
    },
    "on-primary": {
      "$type": "color",
      "$value": "#faf6f0"
    },
    "secondary": {
      "$type": "color",
      "$value": "#9a6a4f"
    },
    "on-secondary": {
      "$type": "color",
      "$value": "#faf6f0"
    },
    "tertiary": {
      "$type": "color",
      "$value": "#b8553a"
    },
    "on-tertiary": {
      "$type": "color",
      "$value": "#faf6f0"
    },
    "neutral": {
      "$type": "color",
      "$value": "#f7f3ee"
    },
    "surface": {
      "$type": "color",
      "$value": "#f7f3ee"
    },
    "surface-container": {
      "$type": "color",
      "$value": "#efe7dd"
    },
    "surface-container-high": {
      "$type": "color",
      "$value": "#e4d8ca"
    },
    "on-surface": {
      "$type": "color",
      "$value": "#2a211c"
    },
    "on-surface-variant": {
      "$type": "color",
      "$value": "#5c5048"
    },
    "outline": {
      "$type": "color",
      "$value": "#cbbfb2"
    },
    "error": {
      "$type": "color",
      "$value": "#9a3412"
    },
    "on-error": {
      "$type": "color",
      "$value": "#faf6f0"
    }
  },
  "typography": {
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Fraunces",
        "fontSize": "48px",
        "fontWeight": 600,
        "lineHeight": 1.05,
        "letterSpacing": "-0.02em"
      }
    },
    "headline-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Fraunces",
        "fontSize": "28px",
        "fontWeight": 600,
        "lineHeight": 1.1
      }
    },
    "title-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Fraunces",
        "fontSize": "22px",
        "fontWeight": 600,
        "lineHeight": 1.15
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "15px",
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "13px",
        "fontWeight": 400,
        "lineHeight": 1.45
      }
    },
    "label-caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "11px",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "0.08em"
      }
    },
    "label-cta": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "13px",
        "fontWeight": 600,
        "lineHeight": 1,
        "letterSpacing": "0.02em"
      }
    }
  },
  "rounded": {
    "sm": {
      "$type": "dimension",
      "$value": "4px"
    },
    "md": {
      "$type": "dimension",
      "$value": "8px"
    },
    "cover": {
      "$type": "dimension",
      "$value": "6px"
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px"
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension"
    },
    "xs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "40px",
      "$type": "dimension"
    },
    "gallery-gap": {
      "$value": "24px",
      "$type": "dimension"
    },
    "cover-aspect": {
      "$value": "2 / 3"
    }
  },
  "motion": {
    "flip": {
      "$type": "transition",
      "$value": {
        "duration": {
          "$type": "duration",
          "$value": "450ms"
        },
        "timingFunction": {
          "$type": "cubicBezier",
          "$value": [
            0.25,
            0.1,
            0.25,
            1.0
          ]
        },
        "delay": {
          "$type": "duration",
          "$value": "0ms"
        }
      }
    },
    "none": {
      "$type": "transition",
      "$value": {
        "duration": {
          "$type": "duration",
          "$value": "0ms"
        },
        "timingFunction": {
          "$type": "cubicBezier",
          "$value": [
            0.0,
            0.0,
            1.0,
            1.0
          ]
        },
        "delay": {
          "$type": "duration",
          "$value": "0ms"
        }
      }
    }
  },
  "components": {
    "book-flip": {
      "perspective": {
        "$value": "800px"
      },
      "rounded": {
        "$value": "{rounded.cover}"
      }
    },
    "book-flip-inner": {
      "transition": {
        "$value": "{motion.flip}"
      }
    },
    "book-flip-front": {
      "backgroundColor": {
        "$value": "{colors.surface-container}"
      },
      "rounded": {
        "$value": "{rounded.cover}"
      }
    },
    "book-flip-back-image": {
      "rounded": {
        "$value": "{rounded.cover}"
      }
    },
    "book-flip-back-info": {
      "backgroundColor": {
        "$value": "{colors.surface-container}"
      },
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "typography": {
        "$value": "{typography.body-md}"
      },
      "rounded": {
        "$value": "{rounded.cover}"
      },
      "padding": {
        "$value": "{spacing.lg}"
      }
    },
    "book-flip-title": {
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "typography": {
        "$value": "{typography.title-md}"
      }
    },
    "book-flip-meta": {
      "textColor": {
        "$value": "{colors.on-surface-variant}"
      },
      "typography": {
        "$value": "{typography.label-caps}"
      }
    },
    "book-flip-cta": {
      "backgroundColor": {
        "$value": "{colors.primary}"
      },
      "textColor": {
        "$value": "{colors.on-primary}"
      },
      "typography": {
        "$value": "{typography.label-cta}"
      },
      "rounded": {
        "$value": "{rounded.sm}"
      },
      "padding": {
        "$value": "{spacing.md}"
      }
    },
    "book-flip-cta-hover": {
      "backgroundColor": {
        "$value": "{colors.primary-strong}"
      }
    }
  }
}
