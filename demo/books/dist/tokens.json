{
  "$description": "A warm, literary design system for a flip-gallery book site. Evolves the \"Shelf & Spine\" pilot into the production system behind demo/books/site: the same paper-and-ink palette, Fraunces/Inter type, and 0.45s flip, plus a cover-typography concern that bakes genre-appropriate titling onto textless covers and a Kindle-ratio + thumbnail-legibility QA contract. Reuses the motion, gradient, and glass (blur/shadow) extensions; adds NO new token type.",
  "colors": {
    "primary": {
      "$type": "color",
      "$value": "#3a2d28"
    },
    "primary-strong": {
      "$type": "color",
      "$value": "#241b17"
    },
    "on-primary": {
      "$type": "color",
      "$value": "#faf6f0"
    },
    "secondary": {
      "$type": "color",
      "$value": "#9a6a4f"
    },
    "on-secondary": {
      "$type": "color",
      "$value": "#faf6f0"
    },
    "tertiary": {
      "$type": "color",
      "$value": "#b8553a"
    },
    "on-tertiary": {
      "$type": "color",
      "$value": "#faf6f0"
    },
    "neutral": {
      "$type": "color",
      "$value": "#f7f3ee"
    },
    "surface": {
      "$type": "color",
      "$value": "#f7f3ee"
    },
    "surface-container": {
      "$type": "color",
      "$value": "#efe7dd"
    },
    "surface-container-high": {
      "$type": "color",
      "$value": "#e4d8ca"
    },
    "on-surface": {
      "$type": "color",
      "$value": "#2a211c"
    },
    "on-surface-variant": {
      "$type": "color",
      "$value": "#5c5048"
    },
    "outline": {
      "$type": "color",
      "$value": "#cbbfb2"
    },
    "error": {
      "$type": "color",
      "$value": "#9a3412"
    },
    "on-error": {
      "$type": "color",
      "$value": "#faf6f0"
    },
    "cover-ink-light": {
      "$type": "color",
      "$value": "#f2f6ff"
    },
    "cover-ink-dark": {
      "$type": "color",
      "$value": "#241f1a"
    },
    "cover-scrim": {
      "$type": "color",
      "$value": "rgba(4, 6, 14, 0.86)"
    },
    "cover-cream-zone": {
      "$type": "color",
      "$value": "#efe6d2"
    }
  },
  "typography": {
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Fraunces",
        "fontSize": "48px",
        "fontWeight": 600,
        "lineHeight": 1.05,
        "letterSpacing": "-0.02em"
      }
    },
    "headline-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Fraunces",
        "fontSize": "28px",
        "fontWeight": 600,
        "lineHeight": 1.1
      }
    },
    "title-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Fraunces",
        "fontSize": "22px",
        "fontWeight": 600,
        "lineHeight": 1.15
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "15px",
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "13px",
        "fontWeight": 400,
        "lineHeight": 1.45
      }
    },
    "label-caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "11px",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "0.08em"
      }
    },
    "label-cta": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "13px",
        "fontWeight": 600,
        "lineHeight": 1,
        "letterSpacing": "0.02em"
      }
    },
    "cover-title": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Anton",
        "fontSize": "220px",
        "fontWeight": 700,
        "lineHeight": 1.04,
        "letterSpacing": "0em"
      }
    },
    "cover-author": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Oswald",
        "fontSize": "58px",
        "fontWeight": 500,
        "lineHeight": 1.0,
        "letterSpacing": "0.12em"
      }
    }
  },
  "rounded": {
    "sm": {
      "$type": "dimension",
      "$value": "4px"
    },
    "md": {
      "$type": "dimension",
      "$value": "8px"
    },
    "cover": {
      "$type": "dimension",
      "$value": "6px"
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px"
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension"
    },
    "xs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "40px",
      "$type": "dimension"
    },
    "gallery-gap": {
      "$value": "24px",
      "$type": "dimension"
    },
    "cover-aspect": {
      "$value": "2 / 3"
    },
    "cover-safe-inset": {
      "$value": "96px",
      "$type": "dimension"
    }
  },
  "motion": {
    "flip": {
      "$type": "transition",
      "$value": {
        "duration": {
          "$type": "duration",
          "$value": "450ms"
        },
        "timingFunction": {
          "$type": "cubicBezier",
          "$value": [
            0.25,
            0.1,
            0.25,
            1.0
          ]
        },
        "delay": {
          "$type": "duration",
          "$value": "0ms"
        }
      }
    },
    "none": {
      "$type": "transition",
      "$value": {
        "duration": {
          "$type": "duration",
          "$value": "0ms"
        },
        "timingFunction": {
          "$type": "cubicBezier",
          "$value": [
            0.0,
            0.0,
            1.0,
            1.0
          ]
        },
        "delay": {
          "$type": "duration",
          "$value": "0ms"
        }
      }
    }
  },
  "gradients": {
    "cover-dark-backdrop": {
      "$type": "gradient",
      "$value": [
        {
          "color": "#11141c",
          "position": "0%"
        },
        {
          "color": "#2b2620",
          "position": "100%"
        }
      ],
      "$extensions": {
        "designmd": {
          "type": "linear",
          "angle": "180deg"
        }
      }
    },
    "cover-cream-backdrop": {
      "$type": "gradient",
      "$value": [
        {
          "color": "#efe6d2",
          "position": "0%"
        },
        {
          "color": "#e4d8ca",
          "position": "100%"
        }
      ],
      "$extensions": {
        "designmd": {
          "type": "linear",
          "angle": "180deg"
        }
      }
    }
  },
  "shadow": {
    "rest": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(42, 33, 28, 0.14)",
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "16px",
        "spread": "0px"
      }
    },
    "cover-title-glow": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(0, 0, 0, 0.55)",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "36px",
        "spread": "0px"
      }
    }
  },
  "components": {
    "book-flip": {
      "perspective": {
        "$value": "800px"
      },
      "rounded": {
        "$value": "{rounded.cover}"
      },
      "shadow": {
        "$value": "{shadow.rest}"
      }
    },
    "book-flip-inner": {
      "transition": {
        "$value": "{motion.flip}"
      }
    },
    "book-flip-front": {
      "backgroundColor": {
        "$value": "{colors.surface-container}"
      },
      "rounded": {
        "$value": "{rounded.cover}"
      }
    },
    "book-flip-back-image": {
      "rounded": {
        "$value": "{rounded.cover}"
      }
    },
    "book-flip-back-info": {
      "backgroundColor": {
        "$value": "{colors.surface-container}"
      },
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "typography": {
        "$value": "{typography.body-md}"
      },
      "rounded": {
        "$value": "{rounded.cover}"
      },
      "padding": {
        "$value": "{spacing.lg}"
      }
    },
    "book-flip-title": {
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "typography": {
        "$value": "{typography.title-md}"
      }
    },
    "book-flip-meta": {
      "textColor": {
        "$value": "{colors.on-surface-variant}"
      },
      "typography": {
        "$value": "{typography.label-caps}"
      }
    },
    "book-flip-cta": {
      "backgroundColor": {
        "$value": "{colors.primary}"
      },
      "textColor": {
        "$value": "{colors.on-primary}"
      },
      "typography": {
        "$value": "{typography.label-cta}"
      },
      "rounded": {
        "$value": "{rounded.sm}"
      },
      "padding": {
        "$value": "{spacing.md}"
      }
    },
    "book-flip-cta-hover": {
      "backgroundColor": {
        "$value": "{colors.primary-strong}"
      }
    },
    "cover-dark": {
      "typography": {
        "$value": "{typography.cover-title}"
      },
      "textColor": {
        "$value": "{colors.cover-ink-light}"
      },
      "backgroundColor": {
        "$value": "{colors.cover-scrim}"
      },
      "backdrop": {
        "$value": "{gradients.cover-dark-backdrop}"
      },
      "shadow": {
        "$value": "{shadow.cover-title-glow}"
      },
      "padding": {
        "$value": "{spacing.cover-safe-inset}"
      }
    },
    "cover-cream": {
      "typography": {
        "$value": "{typography.cover-title}"
      },
      "textColor": {
        "$value": "{colors.cover-ink-dark}"
      },
      "backgroundColor": {
        "$value": "{colors.cover-cream-zone}"
      },
      "padding": {
        "$value": "{spacing.cover-safe-inset}"
      }
    }
  }
}
