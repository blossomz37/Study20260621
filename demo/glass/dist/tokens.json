{
  "$description": "Frosted-glass cards floating over the Aurora gradient backdrop. Composes the `gradients` module (Module A) as the backdrop and adds two new value groups: `blur` (no DTCG type \u2014 a documented local invention) and `shadow` (native DTCG composite). Pilot case for the glass effect family and the C5 contrast fix.",
  "colors": {
    "primary": {
      "$type": "color",
      "$value": "#5b21b6"
    },
    "primary-strong": {
      "$type": "color",
      "$value": "#4c1d95"
    },
    "on-primary": {
      "$type": "color",
      "$value": "#f5f3ff"
    },
    "secondary": {
      "$type": "color",
      "$value": "#2563eb"
    },
    "tertiary": {
      "$type": "color",
      "$value": "#db2777"
    },
    "accent": {
      "$type": "color",
      "$value": "#f59e0b"
    },
    "surface": {
      "$type": "color",
      "$value": "#0b1020"
    },
    "on-surface": {
      "$type": "color",
      "$value": "#eef0fb"
    },
    "on-surface-variant": {
      "$type": "color",
      "$value": "#c7cbe0"
    },
    "glass-fill": {
      "$type": "color",
      "$value": "rgba(255,255,255,0.10)"
    },
    "glass-fill-strong": {
      "$type": "color",
      "$value": "rgba(255,255,255,0.16)"
    },
    "glass-border": {
      "$type": "color",
      "$value": "rgba(255,255,255,0.22)"
    },
    "glass-shadow": {
      "$type": "color",
      "$value": "rgba(8,10,25,0.45)"
    }
  },
  "typography": {
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Sora",
        "fontSize": "44px",
        "fontWeight": 700,
        "lineHeight": 1.08,
        "letterSpacing": "-0.02em"
      }
    },
    "title-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Sora",
        "fontSize": "22px",
        "fontWeight": 600,
        "lineHeight": 1.2
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "17px",
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    },
    "label-caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "12px",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "0.12em"
      }
    }
  },
  "rounded": {
    "md": {
      "$type": "dimension",
      "$value": "12px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "20px"
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px"
    }
  },
  "spacing": {
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "64px",
      "$type": "dimension"
    }
  },
  "gradients": {
    "hero": {
      "$type": "gradient",
      "$value": [
        {
          "color": "{colors.primary}",
          "position": "0%"
        },
        {
          "color": "{colors.tertiary}",
          "position": "55%"
        },
        {
          "color": "{colors.accent}",
          "position": "100%"
        }
      ],
      "$extensions": {
        "designmd": {
          "type": "linear",
          "angle": "135deg"
        }
      }
    }
  },
  "shadow": {
    "glass": {
      "$type": "shadow",
      "$value": {
        "color": "{colors.glass-shadow}",
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "32px",
        "spread": "0px"
      }
    }
  },
  "blur": {
    "$description": "Non-standard local extension: DTCG defines no backdrop-filter/blur type. Values are dimensions consumed as `backdrop-filter: blur(<value>)`.",
    "glass": {
      "$type": "dimension",
      "$value": "20px",
      "$extensions": {
        "designmd": {
          "role": "backdrop-blur"
        }
      }
    },
    "glass-strong": {
      "$type": "dimension",
      "$value": "40px",
      "$extensions": {
        "designmd": {
          "role": "backdrop-blur"
        }
      }
    }
  },
  "components": {
    "glass-card": {
      "backgroundColor": {
        "$value": "{colors.glass-fill}"
      },
      "backdropBlur": {
        "$value": "{blur.glass}"
      },
      "borderColor": {
        "$value": "{colors.glass-border}"
      },
      "shadow": {
        "$value": "{shadow.glass}"
      },
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "rounded": {
        "$value": "{rounded.lg}"
      },
      "padding": {
        "$value": "{spacing.lg}"
      },
      "backdrop": {
        "$value": "{gradients.hero}"
      }
    },
    "glass-card-title": {
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "typography": {
        "$value": "{typography.title-md}"
      }
    },
    "glass-badge": {
      "backgroundColor": {
        "$value": "{colors.glass-fill-strong}"
      },
      "backdropBlur": {
        "$value": "{blur.glass-strong}"
      },
      "borderColor": {
        "$value": "{colors.glass-border}"
      },
      "textColor": {
        "$value": "{colors.on-surface}"
      },
      "rounded": {
        "$value": "{rounded.full}"
      },
      "padding": {
        "$value": "{spacing.sm}"
      },
      "backdrop": {
        "$value": "{gradients.hero}"
      }
    }
  }
}
